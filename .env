# Copy to `.env` next to docker-compose.synology.yml on the NAS and fill in.
# `.env` is gitignored — the real secret never enters version control.
#
# Generate the value with:  openssl rand -base64 32
# Keep it stable: changing it logs every user out (otherwise harmless).
ROCKET_SECRET_KEY=
DATABASE_URL=postgres://flugbuech:flugbuech-dev-password@localhost/flugbuech
TEST_DATABASE_URL=postgres://flugbuech:flugbuech-dev-password@localhost/flugbuech_test
